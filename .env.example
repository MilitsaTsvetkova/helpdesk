DATABASE_URL=postgresql://helpdesk:helpdesk@localhost:5432/helpdesk
PORT=3000

# Required: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional: comma-separated list of allowed frontend origins (defaults to http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173

# Postgres credentials (used by docker-compose)
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk
POSTGRES_DB=helpdesk

# Inbound email webhook — set to any strong random string; send it as
# `Authorization: Bearer <secret>` or `X-Webhook-Secret: <secret>` from your
# email provider. If unset the endpoint accepts all requests (dev only).
# Generate with: openssl rand -base64 32
INBOUND_EMAIL_WEBHOOK_SECRET=

# Seed credentials — change before running seed in any shared or staging environment
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# Required for the "Polish" reply button (uses the Vercel AI SDK + gpt-5.4-nano)
OPENAI_API_KEY=
