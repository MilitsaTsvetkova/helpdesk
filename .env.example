DATABASE_URL=postgresql://helpdesk:helpdesk@localhost:5432/helpdesk
PORT=3000

# Required: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional: comma-separated list of allowed frontend origins (defaults to http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173

# Postgres credentials (used by docker-compose)
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk
POSTGRES_DB=helpdesk

# Inbound email webhook — set to any strong random string; send it as
# `Authorization: Bearer <secret>` or `X-Webhook-Secret: <secret>` from your
# email provider. If unset the endpoint accepts all requests (dev only).
# Generate with: openssl rand -base64 32
INBOUND_EMAIL_WEBHOOK_SECRET=

# Seed credentials — change before running seed in any shared or staging environment
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# Required for the "Polish" reply button (uses the Vercel AI SDK + gpt-5.4-nano)
OPENAI_API_KEY=

# Required to send outbound reply emails to customers (agent replies and
# AI auto-resolutions). SENDGRID_FROM_EMAIL must be a verified sender/domain
# in your SendGrid account.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Optional: Sentry error monitoring for the server. Leave unset to disable
# (Sentry.init no-ops without a DSN). Get this from your Sentry project settings.
SENTRY_DSN=

# Optional: Sentry error monitoring for the client. Must be set in client/.env
# (not the repo root) since `bun run dev:client` runs with cwd client/ and Vite
# only exposes VITE_-prefixed vars to browser code via import.meta.env.
VITE_SENTRY_DSN=
