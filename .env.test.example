TEST_DATABASE_URL=postgresql://helpdesk:helpdesk@localhost:5432/helpdesk_test

# Required: must match BETTER_AUTH_SECRET used by the test server
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=test-better-auth-secret-do-not-use-in-prod

# Test user credentials — seeded by e2e/auth.setup.ts before the test suite runs
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=testpassword123

# Test admin credentials — seeded by e2e/auth.setup.ts before the test suite runs
TEST_ADMIN_EMAIL=testadmin@example.com
TEST_ADMIN_PASSWORD=adminpassword123

# Webhook secret for the inbound-email endpoint (hardcoded in playwright.config.ts).
# Override here only if you need a different local value.
# INBOUND_EMAIL_WEBHOOK_SECRET=test-inbound-webhook-secret-e2e
